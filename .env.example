# Copy this file to `.env` and fill in a key to enable the optional LLM brain.
# The app runs fully WITHOUT any of this (the deterministic brain is the default).
#
#   cp .env.example .env   &&   pip install anthropic

# Anthropic (preferred). Requires:  pip install anthropic
ANTHROPIC_API_KEY=

# OpenAI alternative. Requires:  pip install openai
# OPENAI_API_KEY=

# Optional model override (defaults to claude-opus-4-8 for Anthropic).
# For a cheap, fast reservation bot, claude-haiku-4-5 is a good choice.
# BV_LLM_MODEL=claude-haiku-4-5
